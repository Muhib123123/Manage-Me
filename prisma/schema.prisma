// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// NextAuth.js required models
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// User model
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // Subscription plan: "FREE" | "CREATOR"
  plan             String    @default("FREE")
  planActivatedAt  DateTime? // when paid plan started
  planExpiresAt    DateTime? // when paid plan expires (future Stripe use)

  accounts             Account[]
  sessions             Session[]
  youtubePosts         YoutubePost[]
  instagramPosts       InstagramPost[]
  tiktokPosts          TiktokPost[]
  platformConnections  PlatformConnection[]
  analyticsSnapshots   AnalyticsSnapshot[]
  liveViews            LiveView[]

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// Platform Connections (OAuth Tokens)
// ─────────────────────────────────────────────

model PlatformConnection {
  id           String @id @default(cuid())
  userId       String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  platform     String // "YOUTUBE" or "INSTAGRAM"
  
  // OAuth Tokens
  accessToken  String @db.Text
  refreshToken String? @db.Text
  expiresAt    DateTime?
  
  // Platform specific ID (e.g. YouTube Channel ID or Instagram Business Account ID)
  platformId   String? 
  platformName String? // Human readable name (e.g. Channel Name)
  platformAvatar String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, platform])
}

// ─────────────────────────────────────────────
// YouTube Post model
// ─────────────────────────────────────────────

model YoutubePost {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Video type: normal YouTube video or YouTube Short
  videoType String @default("video") // "video" | "short"

  // YouTube metadata
  title       String
  description String?  @db.Text
  tags        String[]
  privacy     String   @default("public") // "public" | "unlisted" | "private"

  // Storage (UploadThing)
  storageUrl   String
  thumbnailUrl String?

  // Scheduling
  scheduledAt DateTime

  // Status tracking
  status       String  @default("PENDING") // "PENDING" | "UPLOADING" | "DONE" | "FAILED"
  youtubeId    String? // YouTube video ID after successful upload
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Instagram Post model
// ─────────────────────────────────────────────

model InstagramPost {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Media type: photo, video, or reel
  mediaType String @default("PHOTO") // "PHOTO" | "VIDEO" | "REEL"

  // Instagram metadata
  caption String? @db.Text

  // Storage (UploadThing)
  mediaUrls String[]

  // Scheduling
  scheduledAt DateTime

  // Status tracking
  status       String  @default("PENDING") // "PENDING" | "UPLOADING" | "DONE" | "FAILED"
  instagramId  String? // Instagram Media ID after successful publish
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// TikTok Post model
// ─────────────────────────────────────────────

model TiktokPost {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // TikTok metadata
  caption      String? @db.Text
  privacyLevel String  @default("PUBLIC_TO_EVERYONE") // "PUBLIC_TO_EVERYONE" | "MUTUAL_FOLLOW_FRIENDS" | "SELF_ONLY"

  // Permission toggles
  allowDuet    Boolean @default(true)
  allowStitch  Boolean @default(true)
  allowComment Boolean @default(true)

  // Storage (UploadThing)
  videoUrl String

  // Scheduling
  scheduledAt DateTime

  // Status tracking
  status       String  @default("PENDING") // "PENDING" | "UPLOADING" | "DONE" | "FAILED"
  tiktokId     String? // TikTok share_id after successful publish
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Analytics Snapshot model
// ─────────────────────────────────────────────

model AnalyticsSnapshot {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform String // "YOUTUBE" | "INSTAGRAM" | "TIKTOK"

  // Core counts (nullable — not every platform exposes everything)
  subscribers Int? // YouTube subscribers / Instagram followers / TikTok followers
  followers   Int? // alias used for IG/TikTok — kept separate for clarity
  views       Int? // total profile/channel views at snapshot time
  videoViews  Int? // cumulative video views (YouTube, TikTok)
  likes       Int? // cumulative likes (TikTok)

  // Audience gender breakdown (percentages 0–100, may be null if not available)
  malePercent   Float?
  femalePercent Float?
  otherPercent  Float?

  snapshotAt DateTime @default(now())

  @@index([userId, platform, snapshotAt])
}

// ─────────────────────────────────────────────
// Live View model (for SSE live counter)
// ─────────────────────────────────────────────

model LiveView {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform  String // "YOUTUBE" | "INSTAGRAM" | "TIKTOK"
  count     Int    @default(0) // current live viewer / concurrent viewer count
  updatedAt DateTime @updatedAt

  @@unique([userId, platform])
}
